{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "CE",
    "scopeName": "source.ce",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#types"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#functions"
        }
    ],
    "repository": {
        "comments": {
            "name": "comment.line.double-slash.ce",
            "match": "//.*$"
        },
        "strings": {
            "name": "string.quoted.double.ce",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                {
                    "name": "constant.character.escape.ce",
                    "match": "\\\\."
                }
            ]
        },
        "keywords": {
            "name": "keyword.control.ce",
            "match": "\\b(if|else|while|for|return|import|raise|catch|let|fn|type|struct|impl|mut)\\b"
        },
        "types": {
            "patterns": [
                {
                    "name": "storage.type.ce",
                    "match": "\\b(int|string|bool|float|void|i8|i16|i32|i64|i128|u8|u16|u32|u64|u128|f32|f64)\\b"
                },
                {
                    "name": "meta.type.declaration.ce",
                    "match": "\\b(struct|type|trait|enum)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
                    "captures": {
                        "1": {
                            "name": "keyword.declaration.type.ce"
                        },
                        "2": {
                            "name": "entity.name.type.ce"
                        }
                    }
                },
                {
                    "match": "\\b[A-Z][a-zA-Z0-9_]*\\b",
                    "name": "entity.name.type.ce"
                }
            ]
        },
        "numbers": {
            "name": "constant.numeric.ce",
            "match": "\\b\\d+(\\.\\d+)?\\b"
        },
        "functions": {
            "patterns": [
                {
                    "name": "meta.function.declaration.ce",
                    "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
                    "captures": {
                        "1": {
                            "name": "keyword.declaration.function.ce"
                        },
                        "2": {
                            "name": "entity.name.function.ce"
                        }
                    }
                },
                {
                    "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
                    "name": "entity.name.function.call.ce"
                },
                {
                    "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=<[\\s\\S]*?>\\s*\\()",
                    "name": "entity.name.function.call.ce"
                }
            ]
        }
    }
}